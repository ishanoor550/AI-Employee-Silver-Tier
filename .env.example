# AI Employee Environment Configuration
# Copy this to .env and fill in your credentials

# Gmail API Credentials (for Gmail Watcher)
# Get these from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# SMTP Email Settings (for Email MCP Server)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DRY_RUN=true

# LinkedIn Credentials (for LinkedIn Auto-Poster)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
